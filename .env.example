# Copy this file to .env and fill in real values
# .env is gitignored — never commit the real .env

# OpenAI API key — dùng cho pre-commit hook AI review
# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Database credentials
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# JWT secret — use a long random base64 string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Gmail SMTP (create an App Password at myaccount.google.com/apppasswords)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
